{
  "version": 1,
  "business_abbreviations": {
    "hr": "HR",
    "it": "IT",
    "pr": "PR",
    "ceo": "CEO",
    "cfo": "CFO",
    "cto": "CTO"
  },
  "preserve_code_placeholder_patterns": [
    ".*Номер.*",
    ".*РегНомер.*",
    ".*Код.*",
    ".*Code.*",
    ".*Number.*"
  ],
  "governing_phrases": [
    {
      "id": "contract_number_after_no",
      "placeholder_name_pattern": ".*",
      "context_pattern": "(?:№|номер\\s+)\\s*\\[{placeholder}\\]",
      "behavior": "preserve"
    },
    {
      "id": "date_full_goda_suffix",
      "placeholder_name_pattern": ".*(Дата|Date).*",
      "context_pattern": "\\[{placeholder}\\]\\s*года",
      "behavior": "date_ru_full"
    },
    {
      "id": "date_ot_goda",
      "placeholder_name_pattern": ".*(Дата|Date).*",
      "context_pattern": "(?:^|\\s)от\\s+\\[{placeholder}\\]\\s*(?:года|г\\.|год)(?:\\s|$|[.,;:])",
      "behavior": "date_ru_full"
    },
    {
      "id": "date_s_po",
      "placeholder_name_pattern": ".*(Дата|Date|ДатаНачала|ДатаОкончания|ДатаПриема|ДатаУвольнения).*",
      "context_pattern": "(?:^|\\s)(?:с|по|до|начиная\\s+с)\\s+\\[{placeholder}\\](?:\\s*года|\\s|$|[.,;:])",
      "behavior": "date_ru_full"
    },
    {
      "id": "days_bracket_propis",
      "placeholder_name_pattern": ".*(Прописью|Словами|Words|ДнейПрописью|КолДнейПрописью).*",
      "context_pattern": "\\[{placeholder}\\]",
      "behavior": "days_bracket"
    },
    {
      "id": "days_gent_v_techenie",
      "placeholder_name_pattern": ".*(Дней|Days|Срок|КолДней|СрокДней).*",
      "context_pattern": "в\\s+течени[еия]\\s+\\[{placeholder}\\]",
      "behavior": "days_words_gent"
    },
    {
      "id": "days_bracket_kal_days",
      "placeholder_name_pattern": ".*(КолДней|Дней|Days|СрокДней).*",
      "context_pattern": "\\[{placeholder}\\]\\s*(?:\\(|календарн|рабоч|банковск)",
      "behavior": "days_bracket"
    },
    {
      "id": "name_after_ot",
      "placeholder_name_pattern": ".*(ФИО|Сотрудник|Employee).*",
      "context_pattern": "(?:^|\\s)от\\s+\\[{placeholder}\\](?:\\s|$|[.,;:])",
      "case": "gent"
    },
    {
      "id": "name_after_zayavlenie",
      "placeholder_name_pattern": ".*(ФИО|Сотрудник|Employee).*",
      "context_pattern": "(?:^|\\s)заявлени[еяю]\\s+(?:от\\s+)?\\[{placeholder}\\](?:\\s|$|[.,;:])",
      "case": "gent"
    },
    {
      "id": "name_after_prinyat",
      "placeholder_name_pattern": ".*(ФИО|Сотрудник|Employee).*",
      "context_pattern": "(?:^|\\s)принять\\s+\\[{placeholder}\\](?:\\s|$|[.,;:])",
      "case": "accs"
    },
    {
      "id": "name_after_predostavit_otpusk",
      "placeholder_name_pattern": ".*(ФИО|Сотрудник|Employee).*",
      "context_pattern": "предоставить[\\s\\S]{0,180}\\[{placeholder}\\][\\s\\S]{0,180}отпуск",
      "case": "datv"
    },
    {
      "id": "name_uvolit",
      "placeholder_name_pattern": ".*(ФИО|Сотрудник|Employee).*",
      "context_pattern": "(?:уволить|расторгнуть|прекратить)[\\s\\S]{0,120}\\[{placeholder}\\]",
      "case": "accs"
    },
    {
      "id": "name_naznachit",
      "placeholder_name_pattern": ".*(ФИО|Сотрудник|Employee).*",
      "context_pattern": "(?:назначить|перевести)[\\s\\S]{0,120}\\[{placeholder}\\]",
      "case": "accs"
    },
    {
      "id": "name_osvobodit",
      "placeholder_name_pattern": ".*(ФИО|Сотрудник|Employee).*",
      "context_pattern": "(?:освободить|отстранить)[\\s\\S]{0,120}\\[{placeholder}\\]",
      "case": "accs"
    },
    {
      "id": "name_ob_uvolnenii",
      "placeholder_name_pattern": ".*(ФИО|Сотрудник|Employee).*",
      "context_pattern": "(?:об\\s+увольнении|о\\s+прекращении|о\\s+расторжении)[\\s\\S]{0,60}\\[{placeholder}\\]",
      "case": "gent"
    },
    {
      "id": "name_o_perevode",
      "placeholder_name_pattern": ".*(ФИО|Сотрудник|Employee).*",
      "context_pattern": "(?:о\\s+переводе|о\\s+назначении|о\\s+приёме|о\\s+приеме)[\\s\\S]{0,60}\\[{placeholder}\\]",
      "case": "gent"
    },
    {
      "id": "title_na_dolzhnost",
      "placeholder_name_pattern": ".*(Должность|Title|Позиция|Position).*",
      "context_pattern": "на\\s+должность\\s+\\[{placeholder}\\]",
      "case": "gent"
    },
    {
      "id": "title_s_dolzhnosti",
      "placeholder_name_pattern": ".*(Должность|Title|Позиция|Position).*",
      "context_pattern": "(?:с\\s+должности|от\\s+должности)\\s+\\[{placeholder}\\]",
      "case": "gent"
    },
    {
      "id": "title_v_dolzhnosti",
      "placeholder_name_pattern": ".*(Должность|Title|Позиция|Position).*",
      "context_pattern": "(?:в\\s+должности|по\\s+должности)\\s+\\[{placeholder}\\]",
      "case": "gent"
    },
    {
      "id": "title_yavlyaetsya",
      "placeholder_name_pattern": ".*(Должность|Title|Позиция|Position).*",
      "context_pattern": "(?:является|считается|работает|состоит)[\\s\\S]{0,30}\\[{placeholder}\\]",
      "case": "ablt"
    }
  ],
  "department_name_rules": {
    "placeholder_name_patterns": [
      "Подразделение.*",
      ".*Подразделение.*",
      "Департамент.*",
      ".*Департамент.*",
      "Отдел.*",
      ".*Отдел.*",
      ".*ПодразделениеНаименование",
      ".*(Department|Division).*"
    ],
    "behavior": "fixed_form",
    "default_case": "nominative",
    "never_merge_with_adjacent_occurrence": true,
    "preserve_internal_abbreviations": true
  },
  "preserve_abbreviations": [
    "ВОАД",
    "АУП",
    "КПП"
  ]
}
